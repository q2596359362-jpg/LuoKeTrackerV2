<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗺️ 洛克王国地图追踪 V2"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 状态 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="已停止"
            android:textColor="#F44336"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- 按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🚀 开始追踪"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="⏹ 停止"
                android:enabled="false"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 地图导入 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📂 地图文件"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvMapInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未加载地图"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSelectMap"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="📁 选择大地图文件"
            android:layout_marginBottom="16dp" />

        <!-- 校准 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎯 小地图校准"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvCalInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="小地图区域: (0, 0) 200x200"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="X 偏移"
            android:textColor="#999999"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/sbX"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progress="0" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Y 偏移"
            android:textColor="#999999"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/sbY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progress="0" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="宽度"
            android:textColor="#999999"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/sbW"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="500"
            android:progress="200" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="高度"
            android:textColor="#999999"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/sbH"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="500"
            android:progress="200" />

        <!-- 说明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n📖 使用说明\n1. 先导入大地图图片\n2. 调整小地图位置校准\n3. 点击开始追踪\n4. 授予悬浮窗+录屏权限\n5. 切换到游戏即可\n\n💡 双击悬浮窗可展开/收起"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>